#!/bin/sh
# Pre-commit hook: verify curated decks if any deck files are staged.
#
# This is the git-side hook (invoked by `git commit` directly). It runs in
# addition to .claude/hooks/pre-commit-verify.sh (the Claude-harness hook).
# Both hooks detect worktree context: in a worktree, all checks run in full
# blocking mode (the tree is isolated). On shared main with RR_MULTI_AGENT=1,
# deck verification and quiz audit soft-warn instead of hard-blocking.
#
# SOURCE OF TRUTH: this file is invoked directly by git via
# `core.hooksPath=hooks` (set by `npm run hooks:install`). There is no
# mirror to keep in sync — the .git/hooks/pre-commit copy is obsolete.
# Multi-agent detection logic lives in hooks/lib/multi-agent-detect.sh
# and is shared with .claude/hooks/pre-commit-verify.sh.

REPO_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd)

# --- Worktree detection ---
# If this hook is running inside a worktree, the tree is fully isolated from
# other parallel agents. Force MULTI_AGENT=0 so all checks run in full
# blocking mode — worktree isolation removes the shared-state collision risk
# that makes soft-warn necessary on the shared main tree.
MAIN_CHECKOUT="${CLAUDE_PROJECT_DIR:-$REPO_ROOT}"
CURRENT_TOPLEVEL=$(git rev-parse --show-toplevel 2>/dev/null || echo "$MAIN_CHECKOUT")
IN_WORKTREE=0
if [ "$CURRENT_TOPLEVEL" != "$MAIN_CHECKOUT" ]; then
  IN_WORKTREE=1
fi

# --- Multi-agent detection (shared helper, single source of truth) ---
. "$REPO_ROOT/hooks/lib/multi-agent-detect.sh"

# Override: worktree agents are isolated — disable multi-agent soft-warn.
if [ "$IN_WORKTREE" = "1" ]; then
  MULTI_AGENT=0
  MULTI_AGENT_REASON=""
  echo ""
  echo "Running in worktree ($CURRENT_TOPLEVEL) — all checks in full blocking mode."
  echo ""
fi

if [ "$MULTI_AGENT" = "1" ]; then
  echo ""
  echo "⚠️  MULTI-AGENT MODE DETECTED ($MULTI_AGENT_REASON)"
  echo "   Deck verify / quiz audit failures will soft-warn instead of block."
  echo ""
fi

# block_or_warn <label> <fix-hint>
block_or_warn() {
  label="$1"
  hint="$2"
  if [ "$MULTI_AGENT" = "1" ]; then
    echo ""
    echo "⚠️  WARN: $label failed — NOT blocking because multi-agent mode is active."
    echo "   Reason: $MULTI_AGENT_REASON"
    echo "   If this is a real regression, re-run the commit in single-agent mode."
    echo "   $hint"
    echo ""
    return 0
  fi
  echo ""
  echo "ERROR: $label failed. Fix before committing."
  echo "$hint"
  exit 1
}

# --- Deck verification (only when deck files are staged) ---
STAGED_DECKS=$(git diff --cached --name-only -- 'data/decks/*.json')

if [ -n "$STAGED_DECKS" ]; then
  echo "Deck files staged — running batch verification..."
  if ! node scripts/verify-all-decks.mjs 2>&1; then
    block_or_warn "Deck verification" "Run: node scripts/verify-all-decks.mjs --verbose"
  else
    echo "All decks pass verification."
  fi

  echo "Running quiz engine audit..."
  # Capture output once — previous version invoked --full twice (wasteful).
  QUIZ_OUTPUT=$(node scripts/quiz-audit.mjs --full 2>&1)
  QUIZ_EXIT=$?
  echo "$QUIZ_OUTPUT"
  QUIZ_FAILS=$(echo "$QUIZ_OUTPUT" | grep "TOTAL" | grep -oE '[0-9]+ fails' | grep -oE '[0-9]+' | head -1)
  QUIZ_FAILS="${QUIZ_FAILS:-0}"
  if [ "$QUIZ_EXIT" -ne 0 ] || [ "$QUIZ_FAILS" != "0" ]; then
    block_or_warn "Quiz audit" "Run: node scripts/quiz-audit.mjs --full"
  else
    echo "Quiz audit passed."
  fi
fi

# --- Human-prose lint (blocks user-facing text with anti-AI tells) ---
# Scans staged user-facing text files for the five top LLM-tell patterns.
# Override: include [humanizer-verified] in commit message after running
# /humanizer consciously. See .claude/rules/human-prose.md.
if [ -f scripts/lint/check-human-prose.mjs ]; then
  if ! node scripts/lint/check-human-prose.mjs 2>&1; then
    block_or_warn "Human-prose lint" "Run /humanizer with .claude/skills/humanizer/voice-sample.md, or add [humanizer-verified] to commit message if you consciously ran the skill."
  fi
fi

# --- Commit attribution detector (prototype, non-blocking) ---
# Warns if staged files span a wide mtime window, suggesting cross-session
# bundling from concurrent agents. Always exits 0. See gotchas 2026-04-11.
if [ -x "$REPO_ROOT/scripts/lint/check-commit-attribution.sh" ]; then
  "$REPO_ROOT/scripts/lint/check-commit-attribution.sh" >&2 || true
fi
