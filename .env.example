# Terra Miner Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit the .env file to version control

# ComfyUI API endpoint (local sprite generation)
VITE_COMFYUI_API_URL=http://localhost:8188

# Backend API endpoint (quiz data, progress tracking)
VITE_API_URL=http://localhost:3000/api

# App environment
VITE_APP_ENV=development

# OpenRouter API (AI image generation for game sprites)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_MODEL_LANDSCAPE=nanobanana/nanobanana-v2
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Multiplayer web backend WebSocket URL (Fastify MP lobby registry)
# Used by WebSocketTransport to connect to the MP lobby WS endpoint.
# Defaults to ws://localhost:3000/mp/ws in development (no setup needed locally).
VITE_MP_WS_URL=ws://localhost:3000/mp/ws

# Multiplayer web backend REST API URL (Fastify MP lobby REST endpoints)
# Used by webBackend in multiplayerLobbyService.ts for create/join/list REST calls.
# Defaults to http://localhost:3000 in development.
VITE_MP_API_URL=http://localhost:3000
