# Terra Miner Environment Variables
# Copy this file to .env and fill in the values
# NEVER commit the .env file to version control

# ComfyUI API endpoint (local sprite generation)
VITE_COMFYUI_API_URL=http://localhost:8188

# Backend API endpoint (quiz data, progress tracking)
VITE_API_URL=http://localhost:3000/api

# App environment
VITE_APP_ENV=development

# OpenRouter API (AI image generation for game sprites)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_MODEL_LANDSCAPE=nanobanana/nanobanana-v2
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
