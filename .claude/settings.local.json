{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit *)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-commit-verify.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "PostToolUse": []
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Agent(*)",
      "WebSearch",
      "mcp__svelte__*",
      "mcp__context7__*",
      "mcp__cloudflare__*",
      "mcp__wikidata__*",
      "mcp__claude-in-chrome__*",
      "mcp__sqlite__*"
    ]
  },
  "enabledMcpjsonServers": [
    "svelte",
    "context7",
    "cloudflare",
    "wikidata",
    "sqlite"
  ]
}
