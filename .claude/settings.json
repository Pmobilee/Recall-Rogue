{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts/setup-worktree.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "scripts/hooks/end-of-turn-check.sh"
          },
          {
            "type": "command",
            "command": "scripts/hooks/persist-whats-next.sh"
          }
        ]
      }
    ],
    "PreToolUse": [],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "if": "Edit(data/decks/**)",
            "command": "scripts/hooks/post-edit-verify-decks.sh"
          },
          {
            "type": "command",
            "if": "Write(data/decks/**)",
            "command": "scripts/hooks/post-edit-verify-decks.sh"
          },
          {
            "type": "command",
            "if": "MultiEdit(data/decks/**)",
            "command": "scripts/hooks/post-edit-verify-decks.sh"
          },
          {
            "type": "command",
            "if": "Edit(src/services/runSaveService.ts)",
            "command": "scripts/hooks/post-edit-check-rehydration.sh"
          },
          {
            "type": "command",
            "if": "Write(src/services/runSaveService.ts)",
            "command": "scripts/hooks/post-edit-check-rehydration.sh"
          },
          {
            "type": "command",
            "if": "Edit(src/ui/**)",
            "command": "scripts/hooks/post-edit-check-escape-hatches.sh"
          },
          {
            "type": "command",
            "if": "Write(src/ui/**)",
            "command": "scripts/hooks/post-edit-check-escape-hatches.sh"
          },
          {
            "type": "command",
            "if": "Edit(data/decks/**) | Write(data/decks/**) | MultiEdit(data/decks/**) | Edit(public/data/narratives/**) | Write(public/data/narratives/**) | Edit(src/data/mechanics.ts) | Edit(src/data/relics/**) | Edit(src/data/enemies.ts) | Edit(src/data/enemyDialogue.ts) | Edit(src/data/specialEvents.ts) | Edit(src/data/steamAchievements.ts) | Edit(src/data/statusEffects.ts) | Edit(src/i18n/locales/**) | Write(src/i18n/locales/**) | Edit(src/ui/**.svelte) | Write(src/ui/**.svelte)",
            "command": "scripts/hooks/post-edit-check-human-prose.sh"
          }
        ]
      }
    ]
  }
}
